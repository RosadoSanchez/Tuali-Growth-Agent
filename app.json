{
  "expo": {
    "name": "Tuali",
    "slug": "tuali-growth-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tuali",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF7A66"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Capi usa el micrófono para que puedas hablarle por voz."
      },
      "bitcode": false,
      "bundleIdentifier": "com.anonymous.tualigrowthagent"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF7A66",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "package": "com.anonymous.tualigrowthagent"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc"
    ],
    "extra": {
      "apiUrl": "https://tuali-growth-agent-backend-production.up.railway.app",
      "elevenLabsAgentId": "agent_2401ktg0qhxdfgnvxrpehmf4hx5z"
    }
  }
}
