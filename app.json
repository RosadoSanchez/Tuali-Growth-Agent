{
  "expo": {
    "name": "Tuali",
    "slug": "tuali-growth-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tuali",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF7A66"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Capi usa el micrófono para que puedas hablarle por voz."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF7A66",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "extra": {
      "apiUrl": "http://localhost:3000",
      "elevenLabsAgentId": "agent_2401ktg0qhxdfgnvxrpehmf4hx5z"
    }
  }
}
